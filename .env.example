# Nitrado API token — get from https://server.nitrado.net → My Account → API Keys
NITRADO_TOKEN=your_nitrado_token_here

# Nitrado service ID — the number in your server's URL on nitrado.net
NITRADO_SERVICE_ID=your_service_id_here

# Discord webhook URL — right-click a channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# (Optional) Discord role ID to ping on status changes
DISCORD_ALERT_ROLE_ID=
