# Discord bot token — https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Nitrado API token — https://server.nitrado.net → My Account → API Keys
NITRADO_TOKEN=your_nitrado_token_here

# Nitrado service ID — the number in your server's URL on nitrado.net
NITRADO_SERVICE_ID=your_service_id_here

# Discord channel ID for auto-status updates (right-click channel → Copy Channel ID)
STATUS_CHANNEL_ID=your_channel_id_here

# (Optional) Discord role ID to ping on status changes
ALERT_ROLE_ID=
